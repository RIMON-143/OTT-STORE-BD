<b:skin><![CDATA[
:root {
  --accent: #00ffff;
  --accent2: #ff00ff;
  --bg: #000;
  --surface: rgba(255, 255, 255, 0.05);
  --glass-border: rgba(255, 255, 255, 0.1);
}

body {
  background: var(--bg);
  color: #fff;
  font-family: 'Plus Jakarta Sans', sans-serif;
  margin: 0; padding: 0;
  overflow-x: hidden;
}

/* --- Navbar --- */
header {
  position: fixed; top: 20px; left: 50%; transform: translateX(-50%);
  width: 90%; max-width: 1200px;
  background: rgba(0,0,0,0.7); backdrop-filter: blur(25px);
  border: 1px solid var(--glass-border); border-radius: 50px;
  padding: 12px 30px; display: flex; justify-content: space-between; align-items: center;
  z-index: 9999; box-shadow: 0 10px 40px rgba(0,0,0,0.5);
}
.logo h1 {
  font-size: 22px; margin: 0;
  background: linear-gradient(45deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  font-weight: 800;
}
.nav-links { display: flex; gap: 15px; list-style: none; margin: 0; padding: 0; }
.nav-links a {
  color: #aaa; text-decoration: none; font-size: 12px; font-weight: 600; text-transform: uppercase;
  transition: 0.3s;
}
.nav-links a:hover { color: var(--accent); }

/* Hamburger */
.hamburger {
  display: none; flex-direction: column; cursor: pointer; gap: 5px; z-index: 10000;
}
.hamburger div { width: 25px; height: 3px; background: #fff; border-radius: 2px; }

/* --- Hero --- */
.hero { padding: 180px 5% 60px; text-align: center; background: radial-gradient(circle at center, rgba(0,255,255,0.1) 0%, transparent 70%); }
.hero h1 { font-size: clamp(30px, 5vw, 50px); margin-bottom: 20px; letter-spacing: -1px; }
.hero p { color: #aaa; max-width: 700px; margin: 0 auto; font-size: 18px; line-height: 1.6; }

/* LOGIN SYSTEM */
#loginOverlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 99999;
}

.login-box {
  background: rgba(0,0,0,0.9);
  border: 1px solid var(--glass-border);
  padding: 30px;
  border-radius: 20px;
  text-align: center;
  width: 300px;
}

.login-box h2 {
  margin-bottom: 20px;
  color: var(--accent);
}

.login-box input {
  width: 100%;
  padding: 12px;
  margin: 10px 0;
  border-radius: 10px;
  border: none;
  outline: none;
}

.login-box button {
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 10px;
  background: linear-gradient(45deg, var(--accent), var(--accent2));
  font-weight: bold;
  cursor: pointer;
}

#logoutBtn {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: red;
  padding: 10px 20px;
  border-radius: 20px;
  cursor: pointer;
  z-index: 9999;
}




/* --- Features --- */
.features { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 1200px; margin: 0 auto 50px; padding: 0 20px; }
.feature { background: var(--surface); padding: 25px; border-radius: 20px; border: 1px solid var(--glass-border); transition: 0.4s; }
.feature:hover { border-color: var(--accent); transform: translateY(-5px); background: rgba(255,255,255,0.08); }
.feature h2 { color: var(--accent); font-size: 18px; margin-bottom: 10px; }
.feature p { color: #999; font-size: 14px; line-height: 1.5; margin: 0; }

/* --- OTT Grid --- */
.container { max-width: 1400px; margin: 40px auto; padding: 0 20px; }
.section-title { font-size: 24px; margin-bottom: 30px; font-weight: 800; padding-left: 10px; border-left: 4px solid var(--accent); }
.ott-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 25px; }
.card-wrap { position: relative; border-radius: 20px; overflow: hidden; border: 1px solid var(--glass-border); transition: 0.4s; aspect-ratio: 10/14; }
.card-wrap:hover { transform: scale(1.05); border-color: var(--accent); box-shadow: 0 0 20px rgba(0,255,255,0.2); }
.card-wrap img { width: 100%; height: 100%; object-fit: cover; }
.card-overlay { position: absolute; bottom: 0; width: 100%; padding: 15px; background: linear-gradient(0deg, #000, transparent); }
.card-title { font-size: 13px; font-weight: 700; margin: 0; }

/* --- Player --- */
.player-section { max-width: 1100px; margin: 120px auto 40px; }
.video-js { width: 100% !important; height: auto !important; aspect-ratio: 16/9; border-radius: 24px; overflow: hidden; border: 1px solid var(--glass-border); box-shadow: 0 20px 50px rgba(0,0,0,0.8); }
.vjs-big-play-button { background-color: var(--accent) !important; border: none !important; color: #000 !important; border-radius: 50% !important; width: 80px !important; height: 80px !important; line-height: 80px !important; top: 50% !important; left: 50% !important; transform: translate(-50%, -50%) !important; }
.vjs-control-bar { background: rgba(0,0,0,0.8) !important; backdrop-filter: blur(10px); height: 50px !important; }

/* --- CTA --- */
.cta { text-align: center; padding: 80px 20px; background: linear-gradient(to top, rgba(255,0,255,0.05), transparent); margin-top: 50px; }
.btn { display: inline-block; padding: 15px 40px; background: linear-gradient(45deg, var(--accent), var(--accent2)); color: #000; text-decoration: none; font-weight: 800; border-radius: 50px; transition: 0.3s; box-shadow: 0 10px 20px rgba(0,255,255,0.3); }
.btn:hover { transform: scale(1.05); box-shadow: 0 15px 30px rgba(0,255,255,0.5); }

/* --- Mobile --- */
@media (max-width:768px){
  header { width: 85%; padding: 10px 20px; top: 10px; }
  .nav-links { display: none; position: absolute; top: 70px; left: 50%; transform: translateX(-50%); flex-direction: column; background: rgba(0,0,0,0.9); padding: 20px; border-radius: 20px; gap: 15px; }
  .nav-links.active { display: flex; }
  .hamburger { display: flex; }
  .ott-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
  .player-section { margin-top: 100px; }
}
]]></b:skin>
</head>

  
